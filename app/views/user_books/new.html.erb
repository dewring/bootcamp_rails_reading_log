<div class="admin-form-card">
  <div class="admin-form-header">
    <h1>Add to Reading Log</h1>
    <p><%= @book.title %> by <%= @book.author %></p>
  </div>

  <%= form_with model: @user_book, url: user_books_path, html: { class: "admin-form" } do |f| %>
    <%= f.hidden_field :book_id, value: @book.id %>

    <div class="admin-field">
      <%= f.label :status, "Reading Status" %>
      <%= f.select :status, UserBook::STATUSES.map { |s| [s.humanize, s] } %>
    </div>

    <div class="admin-form-submit">
      <%= f.submit "Add to Log" %>
    </div>
  <% end %>

  <div class="admin-form-cancel">
    <%= link_to "← Back to book", @book %>
  </div>
</div>
