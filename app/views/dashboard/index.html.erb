<hgroup>
  <h1>Welcome, <%= current_user.nickname %>!</h1>
  <p>Here's your reading log.</p>
</hgroup>

<% if current_user.user_books.empty? %>
  <article>
    <p>No books yet. <%= link_to "Browse the catalog", books_path %> to add some.</p>
  </article>
<% else %>
  <% UserBook::STATUSES.each do |status| %>
    <% books_for_status = current_user.user_books.where(status: status).includes(:book) %>
    <% next if books_for_status.empty? %>

    <h2><%= status.humanize %></h2>

    <% books_for_status.each do |user_book| %>
      <article>
        <div class="dashboard-book">
          <div>
            <strong><%= link_to user_book.book.title, user_book.book %></strong>
            <small> by <%= user_book.book.author %></small>
          </div>

          <div class="dashboard-actions">
            <%= form_with model: user_book, url: user_book_path(user_book), method: :patch do |f| %>
              <%= f.select :status,
                    UserBook::STATUSES.map { |s| [s.humanize, s] },
                    { selected: user_book.status },
                    { onchange: "this.form.submit()", class: "status-select" } %>
            <% end %>

            <%= button_to "Remove", user_book_path(user_book),
                  method: :delete,
                  data: { turbo_confirm: "Remove from log?" },
                  class: "btn-md" %>
          </div>
        </div>

        <% sessions = user_book.book.reading_sessions.where(user: current_user).order(read_on: :desc) %>
        <% if sessions.any? %>
          <hr>
          <% sessions.each do |session| %>
            <div class="session-row">
              <span><%= session.read_on.strftime("%b %d, %Y") %> — <%= session.pages_read %> pages<%= " — #{session.notes}" if session.notes.present? %></span>
              <div style="display: flex; gap: 0.4rem;">
                <%= link_to "Edit", edit_reading_session_path(session), class: "btn-sm" %>
                <%= button_to "Delete", reading_session_path(session), method: :delete,
                      data: { turbo_confirm: "Delete this session?" },
                      class: "btn-sm btn-danger" %>
              </div>
            </div>
          <% end %>
        <% end %>
      </article>
    <% end %>
  <% end %>
<% end %>
