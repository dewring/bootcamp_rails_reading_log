<article>
  <% if @book.cover_image.attached? %>
    <%= image_tag @book.cover_image, style: "width: 100%; max-height: 300px; object-fit: cover; border-radius: var(--pico-border-radius);" %>
  <% end %>

  <hgroup>
    <h1><%= @book.title %></h1>
    <p>by <%= @book.author %></p>
  </hgroup>

  <% if @book.total_pages %>
    <p><strong><%= @book.total_pages %></strong> pages</p>
  <% end %>

  <% if user_signed_in? && !current_user.admin? %>
    <% user_book = current_user.user_books.find_by(book: @book) %>
    <% if user_book %>
      <p>Your status: <strong><%= user_book.status.humanize %></strong></p>
    <% else %>
      <%= link_to "＋ Add to my reading log", new_user_book_path(book_id: @book.id), role: "button" %>
    <% end %>
  <% end %>

  <footer style="display: flex; gap: 1rem; margin-top: 1rem;">
    <%= link_to "← Back to Catalog", books_path, class: "secondary", role: "button" %>
    <% if current_user&.admin? %>
      <%= link_to "Edit", edit_book_path(@book), role: "button", class: "contrast" %>
    <% end %>
  </footer>
</article>
