<div class="book-show">
  <div class="book-show-cover">
    <% if @book.cover_image.attached? %>
      <%= image_tag @book.cover_image, class: "book-show-image" %>
    <% else %>
      <div class="book-show-no-cover">📚</div>
    <% end %>
  </div>

  <div class="book-show-info">
    <% if @book.genres.any? %>
      <p class="book-show-genre">
        <% @book.genres.each do |genre| %>
          <span><%= genre.name %></span>
        <% end %>
      </p>
    <% end %>

    <h1 class="book-show-title"><%= @book.title %></h1>
    <p class="book-show-author"><%= @book.author %></p>

    <% if @book.total_pages %>
      <p class="book-show-pages"><%= @book.total_pages %> pages</p>
    <% end %>

  <% if @book.description.present? %>
    <%
      desc = @book.description
      main_text = desc.gsub(/\(\[source\]\(.*?\)\)/, "").strip
      source_match = desc.match(/\(\[source\]\((.*?)\)\)/)
    %>
    <p class="book-show-description"><%= main_text %></p>
    <% if source_match %>
      <p class="book-show-source">
        <a href="<%= source_match[1] %>" target="_blank">source</a>
      </p>
    <% end %>
  <% end %>

  <% if @book.subjects.present? %>
    <div class="book-show-subjects">
      <% @book.subjects.each do |subject| %>
        <span><%= subject %></span>
      <% end %>
    </div>
  <% end %>

    <hr class="book-show-divider">

    <div class="book-show-actions">
      <% if user_signed_in? %>
        <% user_book = current_user.user_books.find_by(book: @book) %>
          <% if user_book %>
            <p class="book-show-status">Reading status: <strong><%= user_book.status.humanize %></strong></p>
            <% if policy(ReadingSession.new(user: current_user, book: @book)).new? %>
              <%= link_to "＋ Log Reading Session", new_book_reading_session_path(@book), class: "btn-cta" %>
            <% end %>
            
            <%# only show if they have sessions for this book %>
            <% if policy(@book).most_recent_session? && policy_scope(@book.reading_sessions).exists? %>
              <%= link_to "📖 Most Recent Session", most_recent_session_book_path(@book), class: "btn-cta btn-cta-secondary" %>
            <% end %>
          <% elsif policy(UserBook.new(user: current_user, book: @book)).new? %>
          <%= link_to "＋ Want to Read", new_user_book_path(book_id: @book.id), class: "btn-cta" %>
        <% end %>
      <% end %>

      <% if policy(@book).edit? %>
        <%= link_to "Edit", edit_admin_book_path(@book), class: "btn-cta btn-cta-secondary" %>
      <% end %>
    </div>
  </div>
</div>

<%# Edition section %>
<% if @book_editions.any? %>
  <div class="book-editions-section">
    <h2>Editions</h2>
    <div class="editions-grid">
      <% @book_editions.each do |edition| %>
        <%= link_to "https://openlibrary.org#{edition.ol_edition_key}", target: "_blank", class: "edition-card" do %>
          <div class="edition-cover">
            <% if edition.cover_image.attached? %>
              <%= image_tag edition.cover_image %>
            <% else %>
              <div class="edition-no-cover">📚</div>
            <% end %>
          </div>
          <p><%= edition.publisher %></p>
          <p><%= edition.publish_year %></p>
          <p><%= edition.language %></p>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<%# Reviews section %>
<div class="reviews-section">
  <div class="reviews-header">
    <h2>Reviews <span class="reviews-count"><%= @reviews.count %></span></h2>
    <% if user_signed_in? %>
      <% my_review = current_user.reviews.find_by(book: @book) %>
      <div class="reviews-header-actions">
        <% if my_review && policy(my_review).edit? %>
          <%= link_to "Edit my Review", edit_book_review_path(@book, my_review), class: "btn-cta" %>
        <% end %>
        <% if my_review.blank? && policy(Review.new(user: current_user, book: @book)).new? %>
          <%= link_to "Write a Review", new_book_review_path(@book), class: "btn-cta" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @reviews.empty? %>
    <p class="reviews-empty">No reviews yet. Be the first to write one!</p>
  <% else %>
    <% @reviews.each do |review| %>
      <div class="review-card">
        <div class="review-top">
          <div class="review-meta">
            <div class="review-author"><%= review.user.nickname %></div>
            <div class="review-date"><%= review.created_at.strftime("%Y-%m-%d") %></div>
          </div>
          <div class="review-rating">★ <%= review.rating %> / 5</div>
        </div>
        <p class="review-body"><%= review.body %></p>
      </div>
    <% end %>
  <% end %>
</div> 
