<div class="catalog-header">
  <h1>Book Catalog</h1>
  <%= link_to "🔍 Search Open Library", search_books_path, class: "btn-cta btn-cta-secondary" %>
  <% if policy(Book).new? %>
    <%= link_to "＋ Add Book", new_admin_book_path, class: "btn-cta" %>
  <% elsif policy(Book).discover? %>
    <%= link_to "🔍 Discover", discover_books_path, class: "btn-cta" %>
  <% end %>
</div>

<%= form_with url: books_path, method: :get, class: "search-form" do |f| %>
  <%= f.text_field :q, placeholder: "Search by title or author...", value: params[:q] %>
  <%= f.select :genre,
      Genre::GENRES,
      { include_blank: "All Genres", selected: params[:genre] } %>
  <%= f.submit "Search" %>
<% end %>

<% if @books.empty? %>
  <p>No books in the catalog yet.</p>
<% else %>
  <div class="book-list">
    <% @books.each do |book| %>
      <div class="book-list-item">

        <div class="book-list-cover">
          <%= link_to book do %>
            <% if book.cover_image.attached? %>
              <%= image_tag book.cover_image, class: "book-list-image" %>
            <% else %>
              <div class="book-list-no-cover">📚</div>
            <% end %>
          <% end %>
        </div>

        <div class="book-list-info">
          <% if book.genres.any? %>
            <p class="book-list-genre">
              <% book.genres.each do |genre| %>
                <span><%= genre.name %></span>
              <% end %>
            </p>
          <% end %>
          <h3 class="book-list-title"><%= link_to book.title, book %></h3>
          <p class="book-list-author">by <%= book.author %></p>
        </div>

        <div class="book-list-actions">
          <% if policy(book).edit? %>
            <%= link_to "Edit", edit_admin_book_path(book), class: "btn-cta btn-cta-secondary" %>
          <% end %>
          <% if policy(book).destroy? %>
            <%= button_to "Delete", admin_book_path(book), method: :delete,
                data: { turbo_confirm: "Remove this book?" },
                class: "btn-cta btn-cta-danger" %>
          <% elsif user_signed_in? && policy(UserBook.new(user: current_user, book: book)).new? %>
            <%= link_to "＋ Add to Log", new_user_book_path(book_id: book.id), class: "btn-cta" %>
          <% elsif !user_signed_in? %>
            <a href="#" class="btn-cta"
               onclick="alert('Sign in or sign up to continue.'); window.location='<%= new_user_session_path %>'; return false;">
              ＋ Add to Log
            </a>
          <% end %>
        </div>

      </div>
    <% end %>
  </div>
  <%== @pagy.series_nav %>
<% end %>
