<div class="auth-card">
  <div class="auth-logo">
    <%= link_to root_path do %>
      <span class="auth-logo-icon">📖</span>
      <span class="auth-logo-name">The Books</span>
    <% end %>
  </div>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="auth-field">
      <%= f.text_field :first_name, placeholder: "First name", autocomplete: "given-name" %>
    </div>

    <div class="auth-field">
      <%= f.text_field :last_name, placeholder: "Last name", autocomplete: "family-name" %>
    </div>

    <div class="auth-field">
      <%= f.text_field :nickname, placeholder: "Nickname", autocomplete: "nickname" %>
    </div>

    <div class="auth-field">
      <%= f.email_field :email, placeholder: "Email", autofocus: true, autocomplete: "email" %>
    </div>

    <div class="auth-field">
      <%= f.password_field :password, placeholder: "Password (#{ @minimum_password_length } characters minimum)", autocomplete: "new-password" %>
    </div>

    <div class="auth-field">
      <%= f.password_field :password_confirmation, placeholder: "Confirm password", autocomplete: "new-password" %>
    </div>

    <div class="auth-submit">
      <%= f.submit "Sign up" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= link_to "Already have an account? Log in", new_session_path(resource_name) %>
  </div>
</div>
