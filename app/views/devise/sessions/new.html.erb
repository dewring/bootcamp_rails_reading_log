<div class="auth-card">
  <div class="auth-logo">
    <%= link_to root_path do %>
      <span class="auth-logo-icon">📖</span>
      <span class="auth-logo-name">The Books</span>
    <% end %>
  </div>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
    <div class="auth-field">
      <%= f.email_field :email, placeholder: "Email", autofocus: true, autocomplete: "email" %>
    </div>

    <div class="auth-field">
      <%= f.password_field :password, placeholder: "Password", autocomplete: "current-password" %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="auth-remember">
        <%= f.check_box :remember_me %>
        <%= f.label :remember_me, "Remember me" %>
      </div>
    <% end %>

    <div class="auth-submit">
      <%= f.submit "Log in" %>
    </div>
  <% end %>

  <div class="auth-links">
    <%= link_to "Sign up", new_registration_path(resource_name) %>
    <span class="auth-links-divider">|</span>
    <%= link_to "Forgot password?", new_password_path(resource_name) %>
  </div>
</div>
