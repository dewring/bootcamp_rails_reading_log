<div class="admin-form-card">
  <div class="admin-form-header">
    <h1>Log Reading Session</h1>
    <p><%= @book.title %> by <%= @book.author %></p>
  </div>

  <%= form_with model: [@book, @reading_session], html: { class: "admin-form" } do |f| %>
    <% if @reading_session.errors.any? %>
      <div class="error-messages">
        <ul>
          <% @reading_session.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="admin-field">
      <%= f.label :read_on, "Date" %>
      <%= f.date_field :read_on %>
    </div>

    <div class="admin-field">
      <%= f.label :pages_read, "Pages Read" %>
      <%= f.number_field :pages_read, placeholder: "e.g. 42" %>
    </div>

    <div class="admin-field">
      <%= f.label :notes, "Notes (optional)" %>
      <%= f.text_area :notes, placeholder: "Any thoughts on today's reading...", rows: 3 %>
    </div>

    <div class="admin-form-submit">
      <%= f.submit "Save Session" %>
    </div>
  <% end %>

  <div class="admin-form-cancel">
    <%= link_to "← Back to book", @book %>
  </div>
</div>
