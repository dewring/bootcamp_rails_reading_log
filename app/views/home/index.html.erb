<%# Genre pill navigation %>

<%# Most Read %>
<section class="home-section">
  <h2>Most Read</h2>
  <div class="genre-pills">
  <% Genre::GENRES.each do |genre| %>
    <%= link_to genre, root_path(genre: genre), class: "genre-pill" %>
  <% end %>
  </div>
  <% if @most_read.empty? %>
    <p class="empty-state">No books found for this genre.</p>
  <% else %>
    <div class="book-row">
      <% @most_read.each do |book| %>
        <%= link_to book_path(book), class: "book-card" do %>
          <% if book.cover_image.attached? %>
            <%= image_tag book.cover_image, class: "book-cover" %>
          <% else %>
            <div class="book-cover no-cover">📚</div>
          <% end %>
          <p class="book-title"><%= book.title %></p>
          <p class="book-author"><%= book.author %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>
</section>

<%# New Books %>
<section class="home-section">
  <h2>New Books</h2>
  <div class="book-row">
    <% @new_books.each do |book| %>
      <%= link_to book_path(book), class: "book-card" do %>
        <% if book.cover_image.attached? %>
          <%= image_tag book.cover_image, class: "book-cover" %>
        <% else %>
          <div class="book-cover no-cover">📚</div>
        <% end %>
        <p class="book-title"><%= book.title %></p>
        <p class="book-author"><%= book.author %></p>
      <% end %>
    <% end %>
  </div>
</section>
