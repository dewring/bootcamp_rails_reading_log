<%# Genre pill navigation %>

<%# Most Read %>
<section class="home-section">
  <h2>Most Read</h2>
  <div class="genre-pills">
    <% if params[:genre].present? %>
      <%= link_to "Reset", root_path, class: "genre-pill", style: "background-color: #f5c518; border-color: #e0b000; color: #1a2236; text-decoration: none;" %>
    <% end %>
    <% Genre::GENRES.each do |genre| %>
      <%= link_to genre, root_path(genre: genre), class: "genre-pill #{'genre-pill-active' if params[:genre] == genre}" %>
    <% end %>
  </div>
  <% if @most_read.empty? %>
    <p class="empty-state">No books found for this genre.</p>
  <% else %>
    <div class="book-row">
      <% @most_read.each do |book| %>
        <%= render "home/book_card", book: book %>
      <% end %>
    </div>
  <% end %>
</section>

<%# New Books %>
<section class="home-section">
  <h2>New Books</h2>
  <div class="book-row">
    <% @new_books.each do |book| %>
      <%= render "home/book_card", book: book %>
    <% end %>
  </div>
</section>
